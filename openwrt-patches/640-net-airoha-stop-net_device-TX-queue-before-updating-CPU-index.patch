From: Lorenzo Bianconi <lorenzo@kernel.org>
Subject: [PATCH] net: airoha: stop net_device TX queue before updating CPU index

Stop the netdev TX queue before writing the CPU index register rather
than after.  If the queue is stopped after the CPU index update there is
a window where the hardware has been told new descriptors are available
but a concurrent enqueue can still see the ring as full and return
NETDEV_TX_BUSY without the queue being stopped, leading to a TX stall.

--- a/drivers/net/ethernet/airoha/airoha_eth.c
+++ b/drivers/net/ethernet/airoha/airoha_eth.c
@@ -2155,16 +2155,15 @@ static netdev_tx_t airoha_dev_xmit(struct sk_buff *skb,
 	skb_tx_timestamp(skb);
 	netdev_tx_sent_queue(txq, skb->len);
+	if (q->ndesc - q->queued < q->free_thr) {
+		netif_tx_stop_queue(txq);
+		q->txq_stopped = true;
+	}

 	if (netif_xmit_stopped(txq) || !netdev_xmit_more())
 		airoha_qdma_rmw(qdma, REG_TX_CPU_IDX(qid),
 				TX_RING_CPU_IDX_MASK,
 				FIELD_PREP(TX_RING_CPU_IDX_MASK, index));

-	if (q->ndesc - q->queued < q->free_thr) {
-		netif_tx_stop_queue(txq);
-		q->txq_stopped = true;
-	}
-
 	spin_unlock_bh(&q->lock);

 	return NETDEV_TX_OK;
