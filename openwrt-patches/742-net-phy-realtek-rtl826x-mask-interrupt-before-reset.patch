From: Gilly <gilroyscott1970@gmail.com>
Date: Mon, 20 Apr 2026 00:00:00 +1000
Subject: net: phy: realtek: mask RTL826x interrupt after soft reset
--- a/drivers/net/phy/realtek/realtek_main.c
+++ b/drivers/net/phy/realtek/realtek_main.c
@@ -2654,6 +2654,11 @@ static int rtl826x_config_init(struct phy_device *phydev)

 	msleep(30);

+	/* Soft reset restores VEND2:INER to default (enabled); re-mask before
+	 * autoneg-complete can fire the IRQ. Without this, "nobody cared" kills
+	 * the line permanently. rtl826x_config_intr() re-enables once ready. */
+	phy_write_mmd(phydev, MDIO_MMD_VEND2, RTL826X_VND2_INER, 0);
+
 	ret = rtlgen_phy_patch(phydev);
 	if (ret) {
 		phydev_err(phydev, "patch failed!! %d\n", ret);
